# --- Node identity (copy to .env and customise per physical station) ---
NODE_ID=LBB-NODE-01
NODE_NAME=LBB Monitoring Node
NODE_LOCATION=LBB
TZ=Asia/Jakarta

# --- MQTT broker (Eclipse Mosquitto at the depot) ---
MQTT_HOST=10.10.10.10
MQTT_PORT=1883
MQTT_USERNAME=turnout
MQTT_PASSWORD=password
MQTT_TOPIC_PREFIX=turnout
MQTT_KEEPALIVE=30
MQTT_QOS=1

# --- Local SQLite historian cache ---
SQLITE_PATH=/app/storage/local.db
SQLITE_RETAIN_EVENTS=50000

# --- Timings ---
HEARTBEAT_INTERVAL=5            # seconds between heartbeats
HEALTH_INTERVAL=30              # seconds between device-health snapshots
SAMPLE_INTERVAL=0.5             # seconds between input reads
FAILURE_DEBOUNCE_SECONDS=5      # both-low must persist this long to classify as FAILURE
STATE_PUBLISH_INTERVAL=60       # keepalive re-publish of current state (s)

# --- Input driver: 'simulator' (dev) or 'modbus' (prod, requires mapping) ---
INPUT_DRIVER=simulator
SIMULATOR_TURNOUTS=W1110,W1111,W1112,W1113,W1114

# --- Logging ---
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
